theme = Mariana
window-colorspace = display-p3

font-family = Source Code Pro
font-size = 16

cursor-style = bar
cursor-style-blink = false
adjust-cursor-thickness = 3

maximize = true
quit-after-last-window-closed = true

resize-overlay = never
shell-integration-features = no-cursor, ssh-env
bell-features = no-attention, no-title

notify-on-command-finish = unfocused
notify-on-command-finish-action = notify
notify-on-command-finish-after = 30s

auto-update-channel = tip


# Keybinds
keybind = super+n=new_tab
keybind = super+shift+n=new_window

keybind = f1=clear_screen
keybind = chain=text:!!\n
keybind = f2=clear_screen
keybind = chain=text:git status\n
keybind = super+l=clear_screen
keybind = f3=text:emu_date_reset\n


keybind = super+k=unbind
keybind = super+t=unbind
keybind = super++=unbind
keybind = super+-=unbind
keybind = super+equal=unbind
keybind = super+0=unbind
keybind = super+j=previous_tab
keybind = super+k=next_tab
