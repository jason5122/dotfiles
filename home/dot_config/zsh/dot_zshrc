HISTFILE="$ZDOTDIR/zsh_history"
HISTSIZE=100000
SAVEHIST=100000

setopt HIST_IGNORE_DUPS
setopt EXTENDED_HISTORY
# Experimental.
setopt INC_APPEND_HISTORY
setopt HIST_NO_FUNCTIONS
setopt HIST_REDUCE_BLANKS

PROMPT='%F{green}%n%f@%F{blue}%m%f %F{yellow}%(5~|%-1~/…/%3~|%4~)%f
$ '
# https://git-scm.com/book/sv/v2/Bilaga-A:-Git-in-Other-Environments-Git-in-Zsh
autoload -Uz add-zsh-hook vcs_info
precmd_vcs_info() { vcs_info }
add-zsh-hook precmd precmd_vcs_info
setopt prompt_subst
RPROMPT='$vcs_info_msg_0_'
zstyle ':vcs_info:git:*' formats '%b'

export VISUAL='subl -w'
export PAGER=less
export LESS=-RF

# Preserve our cursor style when exiting tmux or Neovim.
_set_cursor_bar() { printf '\e[6 q' }
add-zsh-hook precmd _set_cursor_bar

# ──────────────────────────────────────────────────────────────────────────────────────────────────
# Completions
# ──────────────────────────────────────────────────────────────────────────────────────────────────
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path "$ZDOTDIR/cache"
zstyle ':completion:*' insert-tab false

fpath=("$ZDOTDIR/completions" $fpath)

# TODO: Should we be enabling extendedglob just for this?
setopt extendedglob
autoload -Uz compinit
if [[ -n $ZDOTDIR/.zcompdump(#qN.mh+24) ]]; then
  compinit
  touch "$ZDOTDIR/.zcompdump"
else
  compinit -C
fi

autoload -U select-word-style
select-word-style bash

# ──────────────────────────────────────────────────────────────────────────────────────────────────
# Keybindings
# ──────────────────────────────────────────────────────────────────────────────────────────────────
# https://unix.stackexchange.com/questions/522663/ctrl-u-deletes-whole-line-regardless-of-cursor-position
bindkey \^U backward-kill-line

# ──────────────────────────────────────────────────────────────────────────────────────────────────
# Miscellaneous
# ──────────────────────────────────────────────────────────────────────────────────────────────────
maybe_source() { [[ -f $1 ]] && . "$1"; }
oath() { ykman oath accounts code -s "$1"; }

maybe_source "$HOMEBREW_PREFIX/opt/fzf/shell/key-bindings.zsh"

alias cm=chezmoi
alias homelab='ssh -t jason@jason-homelab -- tmux new -A -s main'
alias zsh_profile="hyperfine --warmup 20 'zsh -i -c exit'"

# TODO: Document how to download cookies. This command seems to prompt for Keychain Access (doesn't seem to store it though).
# gallery-dl --cookies-from-browser chromium/instagram.com --cookies-export cookies.txt
ig() {
  local out="$HOME/Downloads/to-personal-laptop/gallery-dl"
  gallery-dl -C "$out/cookies.txt" -d "$out" "$1"
}

# ──────────────────────────────────────────────────────────────────────────────────────────────────
# Duolingo
# ──────────────────────────────────────────────────────────────────────────────────────────────────
maybe_source "$HOME/.duolingo/init.sh"

maybe_source "$HOME/google-cloud-sdk/path.zsh.inc"
maybe_source "$HOME/google-cloud-sdk/completion.zsh.inc"

# eval "$(nodenv init -)"

source "$ZDOTDIR/functions/git.zsh"
source "$ZDOTDIR/functions/android.zsh"
source "$ZDOTDIR/plugins/fzf-tab/fzf-tab.plugin.zsh"

alias claude="claude --model 'claude-opus-4-8[1m]'"

# ──────────────────────────────────────────────────────────────────────────────────────────────────
unfunction maybe_source
